GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FAST_MODEL=gemini-3.1-flash-lite
GEMINI_QUALITY_MODEL=gemini-3.5-flash
GEMINI_INTERRUPTION_MODEL=gemini-3.1-flash-lite
# Course preview, curriculum generation, and topic lesson preparation are
# ownership-critical routes fixed to OpenAI gpt-5.4 in code.

# Curriculum prompt rollout. v2 is the optimized pipeline; legacy is the
# conservative rollback path. Canary deterministically selects a percentage
# of users. Shadow double-generation is off unless explicitly enabled.
# CURRICULUM_ROLLOUT_MODE=v2              # legacy | shadow | canary | v2
# CURRICULUM_ROLLOUT_PERCENT=0
# CURRICULUM_ROLLOUT_SEED=trulurn-curriculum-v2
# CURRICULUM_SHADOW_EXECUTE=0
# CURRICULUM_HEALTH_MIN_SAMPLES=20
# CURRICULUM_HEALTH_WINDOW=200
# CURRICULUM_HEALTH_MAX_REPAIR_RATE=0.15
# CURRICULUM_HEALTH_MAX_FAILURE_RATE=0.05
# CURRICULUM_HEALTH_MIN_QUALITY=90
# CURRICULUM_HEALTH_GATE_DISABLED=0
# Optional pricing inputs make curriculum telemetry record estimated per-run cost.
# CURRICULUM_INPUT_USD_PER_MILLION=
# CURRICULUM_CACHED_INPUT_USD_PER_MILLION=
# CURRICULUM_OUTPUT_USD_PER_MILLION=

# Default provider for features that do not have an explicit override.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_PRIMARY_MODEL=gpt-5.4
OPENAI_AGENT_MODEL=gpt-5.4-mini
OPENAI_CONTROL_MODEL=gpt-5.4-mini
OPENAI_PREMIUM_MODEL=gpt-5.4
# Optional low-latency verifier used for source claim/citation auditing.
# OPENAI_GROUNDING_MODEL=gpt-5.4-mini
# GEMINI_GROUNDING_MODEL=gemini-2.5-flash
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=768

# Optional feature routing overrides. Feature names are listed in docs/AI_PROVIDERS.md.
# Supporting tasks use explicit FAST / CONTROL / PREMIUM tiers. Automatic
# cross-provider fallback is disabled; enable it per feature only after evals.
# Course-planning ownership overrides are intentionally ignored.
# AI_FEATURE_TOPIC_PAGE_GENERATION_PROVIDER=gemini
# AI_FEATURE_TOPIC_PAGE_GENERATION_MODEL=gemini-2.5-flash
# AI_FEATURE_SOURCE_ORDERING_PROVIDER=gemini
# AI_FEATURE_SOURCE_ORDERING_FALLBACK_PROVIDERS=openai
# AI_FEATURE_SOURCE_GROUNDING_VERIFICATION_PROVIDER=openai
# AI_FEATURE_SOURCE_GROUNDING_VERIFICATION_MODEL=gpt-5.4-mini
# AI_FEATURE_EMBEDDINGS_PROVIDER=openai
# AI_FEATURE_EMBEDDINGS_MODEL=text-embedding-3-small
# AI_FEATURE_EMBEDDINGS_DIMENSIONS=768
# LOG_AI_USAGE=1
# Exact concurrent AI requests are shared in-process by default.
# AI_SINGLEFLIGHT_DISABLED=1
# Plain AI requests default to 120s. Curriculum planning gets a four-minute
# feature-specific ceiling because its GPT reasoning model can take several minutes.
# AI_REQUEST_TIMEOUT_MS=120000
# AI_FEATURE_CURRICULUM_GENERATION_TIMEOUT_MS=240000
# Web-search tool loops use their own 180s default.
# AI_SEARCH_TIMEOUT_MS=180000
# Exact embedding inputs are cached briefly in-process by default.
# AI_EMBEDDING_CACHE_DISABLED=1
# Privacy-safe aggregate AI usage events are retained for 90 days by default.
# AI_USAGE_PERSISTENCE_DISABLED=1
# RAG_TRACE_QUERY_PREVIEW=0
# Phase 5 rollout defaults. Persisted per-user workflow policies override these.
# RAG_CUTOVER_DEFAULT_MODE=v2
# RAG_CUTOVER_DEFAULT_PERCENT=0
# RAG_CUTOVER_SEED=trulurn-rag-v2
# Cleanup remains blocked until parity and deletion gates pass.
# RAG_CLEANUP_MIN_PARITY_SAMPLES=10
# RAG_CLEANUP_MIN_OVERLAP=0.35
NEXT_PUBLIC_APP_URL=http://localhost:3000
MONGODB_URI=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_ID=
GITHUB_SECRET=

# MarkItDown microservice — converts PDFs, Word, PowerPoint, Excel to Markdown for source-grounded courses
# Start with: cd services/markitdown && uvicorn main:app --host 127.0.0.1 --port 3002
# Leave blank to disable rich-document uploads (plain text sources still work)
MARKITDOWN_SERVICE_URL=http://localhost:3002
# Client-side wait for conversion; image-heavy PDFs caption several images (default: 180s).
# MARKITDOWN_TIMEOUT_MS=180000
# Maximum size of one uploaded source file (default: 25 MB).
# MAX_SOURCE_FILE_BYTES=26214400

# Image captioning inside the MarkItDown service: embedded PDF/figure images are
# described by a cheap vision model and folded into the extracted source text.
# The service reads these from .env.local at startup. Defaults shown; all optional.
# IMAGE_CAPTION_ENABLED=1
# IMAGE_CAPTION_PROVIDER=gemini            # gemini | openai
# IMAGE_CAPTION_MODEL=gemini-2.5-flash     # default depends on provider
# IMAGE_CAPTION_MAX_IMAGES=20              # per document, caps cost
# IMAGE_CAPTION_MIN_DIM=128                # skip images smaller than NxN px (icons/logos)
# IMAGE_CAPTION_MAX_DIM=1024               # downscale before sending, bounds vision cost
# IMAGE_CAPTION_TIMEOUT_MS=30000           # per-image vision call timeout
# IMAGE_CAPTION_CACHE_MAX=512              # exact-image caption reuse per service process
