    {"id":"a10000000000000e","type":"text","text":"QUERY & CONTEXT ROUTING","x":170,"y":-430,"width":250,"height":50,"color":"4"},
    {"id":"a10000000000000f","type":"text","text":"User message\nquestion + selected passage","x":170,"y":-340,"width":230,"height":80},
    {"id":"a100000000000010","type":"text","text":"Intent / question classification\ncurrent page, course-specific, app knowledge, general knowledge, action","x":170,"y":-210,"width":270,"height":110},
    {"id":"a100000000000011","type":"text","text":"Context planner\nDecides whether semantic retrieval is needed","x":170,"y":-50,"width":270,"height":85,"color":"3"},
    {"id":"a100000000000012","type":"text","text":"Retrieval gate\nSkip RAG when current page or direct app context is sufficient","x":170,"y":80,"width":270,"height":95},
    {"id":"a100000000000013","type":"text","text":"Embed query once\nQUESTION_ANSWERING task","x":170,"y":220,"width":230,"height":75},
    {"id":"a100000000000014","type":"text","text":"Parallel candidate retrieval","x":170,"y":340,"width":240,"height":60,"color":"2"},
    {"id":"a100000000000015","type":"text","text":"Relevant lesson pages\ncross-topic teaching context","x":-20,"y":450,"width":210,"height":80},
    {"id":"a100000000000016","type":"text","text":"Relevant prior questions\nlearner conversation memory","x":220,"y":450,"width":210,"height":80},
    {"id":"a100000000000017","type":"text","text":"Relevant source passages\nprimary source evidence","x":460,"y":450,"width":210,"height":80},
    {"id":"a100000000000018","type":"text","text":"Hybrid ranking\nDense + lexical fusion\nterm coverage + phrase match + method agreement","x":170,"y":580,"width":300,"height":115,"color":"2"},
    {"id":"a100000000000019","type":"text","text":"Selection controls\nminimum score + MMR diversity + per-group limits + character budgets","x":170,"y":750,"width":300,"height":110},

