    {"id":"a10000000000001f","type":"text","text":"Workspace context builder\nCombines only the context required for this request","x":650,"y":200,"width":270,"height":95,"color":"3"},

    {"id":"a100000000000020","type":"text","text":"GENERATION & VERIFICATION","x":170,"y":920,"width":270,"height":50,"color":"4"},
    {"id":"a100000000000021","type":"text","text":"Prompt assembly\nquestion + page + course context + learner memory + retrieved evidence","x":170,"y":1010,"width":310,"height":115,"color":"3"},
    {"id":"a100000000000022","type":"text","text":"Agent generation\nDirect synthesized answer","x":170,"y":1170,"width":250,"height":80,"color":"2"},
    {"id":"a100000000000023","type":"text","text":"Source-grounding verifier\nclaim ↔ evidence check\nrepair, conflict handling, or abstain","x":520,"y":1170,"width":280,"height":110,"color":"1"},
    {"id":"a100000000000024","type":"text","text":"Final response\nanswer + valid citations when required","x":170,"y":1330,"width":270,"height":90,"color":"2"},

    {"id":"a100000000000025","type":"text","text":"MEMORY & OBSERVABILITY","x":-430,"y":920,"width":260,"height":50,"color":"4"},
    {"id":"a100000000000026","type":"text","text":"Store conversation\nuser question + agent answer + topic/page position + grounding report","x":-430,"y":1030,"width":300,"height":120},
    {"id":"a100000000000027","type":"text","text":"Embed learner question asynchronously\nFeeds future conversational retrieval","x":-430,"y":1200,"width":300,"height":90},
    {"id":"a100000000000028","type":"text","text":"Retrieval trace\nselected candidates, scores, methods, errors, duration, rollout version","x":-100,"y":750,"width":300,"height":115},
    {"id":"a100000000000029","type":"text","text":"Future graph enrichment\nExtract discussed concepts → match existing topics → provisional personal nodes/edges","x":-430,"y":1340,"width":320,"height":120,"color":"6"}
