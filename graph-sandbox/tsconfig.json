{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "../*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next-sandbox/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    "../components/graph/**/*.ts",
    "../components/graph/**/*.tsx",
    "../lib/graph/**/*.ts",
    "../lib/ai/**/*.ts",
    "../lib/course-generation/research.ts",
    ".next-sandbox-build/types/**/*.ts"
  ],
  "exclude": [
    "../node_modules"
  ]
}
